# OpenRouter API (Primary LLM Provider)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3-8b-instruct

# Cohere API (Embeddings)
COHERE_API_KEY=your_cohere_api_key_here

# Qdrant Cloud (Vector Database)
QDRANT_URL=your_qdrant_url_here
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION_NAME=humanoid_ai_book

# Neon Postgres (Relational Database)
NEON_DATABASE_URL=postgresql://user:password@host.db.neon.tech/dbname?sslmode=require

# Optional: OpenAI (Fallback)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Google AI (Fallback)
GOOGLE_API_KEY=your_google_api_key_here

# Frontend API URL (for chat widget)
# REACT_APP_API_URL=http://localhost:8000/api/v1